      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Busca libros en el inventario por título o autor para saber precio y stock. Úsalo SIEMPRE que el cliente pregunte por un libro o autor.",
        "operation": "executeQuery",
        "query": "SELECT l.titulo, a.nombre AS autor, l.precio, l.stock\nFROM libros l\nLEFT JOIN libros_autores la ON l.libro_id = la.libro_id\nLEFT JOIN autores a ON la.autor_id = a.autor_id\nWHERE LOWER(l.titulo) LIKE LOWER('%' || '{{ $fromAI(\"busqueda\", \"Nombre del libro o autor a buscar\") }}' || '%')\n   OR LOWER(a.nombre) LIKE LOWER('%' || '{{ $fromAI(\"busqueda\", \"Nombre del libro o autor a buscar\") }}' || '%')\nLIMIT 5;",
        "options": {}
      },
