        "jsCode": "// Tomamos el base64 que nos entregó el nodo anterior\nlet rawBase64 = $input.item.json.base64;\n\n// Si el texto trae basura al inicio (como \"data:audio/ogg;base64,\"), se la quitamos\nif (rawBase64 && rawBase64.includes(\",\")) {\n    rawBase64 = rawBase64.split(\",\")[1];\n}\n\nif (!rawBase64) {\n    throw new Error(\"No se pudo descargar el audio desde Evolution API.\");\n}\n\n// Rescatamos el número de celular buscando hacia atrás en el nodo Webhook\nconst remoteJid = $('Webhook').item.json.body.data.key.remoteJid;\n\n// Empaquetamos el archivo para Groq\n$input.item.binary = {\n  data: {\n    data: rawBase64,\n    mimeType: 'audio/ogg',\n    fileName: 'audio.ogg'\n  }\n};\n$input.item.json = { remoteJid: remoteJid }; \n\nreturn $input.item;"
      },
