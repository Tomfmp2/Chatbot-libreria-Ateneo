        "operation": "executeQuery",
        "query": "SELECT \n  (SELECT string_agg(nombre_categoria, ', ') FROM categorias) AS generos_disponibles,\n  (SELECT string_agg(nombre, ', ') FROM (SELECT nombre FROM autores ORDER BY RANDOM() LIMIT 8) sub) AS autores_destacados;",
